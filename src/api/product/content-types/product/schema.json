{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Products displayed in collection page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "designer": {
      "type": "string",
      "required": true
    },
    "material": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["Seating", "Tables", "Storage", "Lighting", "Accessories"],
      "required": true
    },
    "shortDescription": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "required": true
    },
    "hoverLabel": {
      "type": "string",
      "default": "View Details"
    },
    "inquireLabel": {
      "type": "string",
      "default": "Inquire"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    }
  }
}